# Core Settings
PROJECT_NAME="Virtual Influencer Engine"
ENV="development" # development, production

# Database & Redis
DATABASE_URL="postgresql://user:password@localhost:5432/influencer_db"
REDIS_URL="redis://localhost:6379/0"

# AI Provider Keys
OPENAI_API_KEY="sk-..."
# Active Platforms (comma separated: instagram,facebook,twitter,threads)
ACTIVE_PLATFORMS=instagram,facebook,twitter
ANTHROPIC_API_KEY="sk-ant-..."
HUGGINGFACE_TOKEN="hf_..."

# Social Media - Meta (Facebook, Instagram)
# Register app at https://developers.facebook.com/ (Business app type)
META_APP_ID="your_app_id"
META_APP_SECRET="your_app_secret"
META_ACCESS_TOKEN="your_long_lived_user_token"
# Page/Account IDs
FACEBOOK_PAGE_ID="your_page_id"
INSTAGRAM_ACCOUNT_ID="your_instagram_business_account_id"

# Social Media - Threads (SEPARATE App from Meta!)
# Create a NEW app at https://developers.facebook.com/ with Use Case "Access the Threads API"
# Threads uses a different API endpoint (graph.threads.net) and its own OAuth token.
# Token duration: 60 days (renewable), NO permanent token available for Threads.
# THREADS_APP_ID: find it in your Threads App Dashboard > Settings > Basic (only needed for manual OAuth setup/token renewal)
THREADS_APP_SECRET="your_threads_app_secret"
THREADS_ACCESS_TOKEN="your_threads_long_lived_token"
THREADS_USER_ID="your_threads_user_id"

# Threads Content Strategy
# Ratio of text-only posts on Threads (0.0 = always image, 1.0 = always text-only)
THREADS_TEXT_ONLY_RATIO=0.7

# Social Media - Twitter (X)
TWITTER_API_KEY="your_api_key"
TWITTER_API_SECRET="your_api_secret"
TWITTER_ACCESS_TOKEN="your_access_token"
TWITTER_ACCESS_TOKEN_SECRET="your_access_token_secret"
TWITTER_BEARER_TOKEN="your_bearer_token"

# Image Generation
# If using Replicate for SDXL
REPLICATE_API_TOKEN="r8_..."
